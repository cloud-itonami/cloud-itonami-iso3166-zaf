#:culture{:id "zaf.dish.bobotie", :name "Bobotie", :country "ZAF", :kind :dish, :summary "South African dish of spiced minced meat baked with an egg-based topping, known in the Cape of Good Hope since the 17th century and adopted by the Cape Malay community after being introduced from Europe via the Dutch.", :url "https://en.wikipedia.org/wiki/Bobotie", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.dish.bunny-chow", :name "Bunny chow", :country "ZAF", :kind :dish, :summary "Indian South African fast-food dish of a hollowed-out loaf of white bread filled with curry, originating among Indian South Africans in Durban, dated to the 1940s.", :url "https://en.wikipedia.org/wiki/Bunny_chow", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.dish.boerewors", :name "Boerewors", :country "ZAF", :kind :dish, :summary "Sausage that originated in South Africa (Afrikaans for 'farmer's sausage'), regulated to contain at least 90 percent meat or fat from beef, pork, lamb or goat, traditionally grilled at a braai and served with pap.", :url "https://en.wikipedia.org/wiki/Boerewors", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.product.biltong", :name "Biltong", :country "ZAF", :kind :product, :summary "Air-dried, cured meat that originated in Southern Africa and became integral to South African culture and identity.", :url "https://en.wikipedia.org/wiki/Biltong", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.beverage.rooibos", :name "Rooibos", :country "ZAF", :kind :beverage, :summary "Herbal tea plant endemic to South Africa's Cederberg region in the Western Cape; the EU grants rooibos protected designation of origin (PDO) status, requiring EU-marketed product to be grown in the Cederberg.", :url "https://en.wikipedia.org/wiki/Rooibos", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.festival.kaapse-klopse", :name "Kaapse Klopse", :country "ZAF", :kind :festival, :summary "Traditionally Cape Coloured minstrel festival that takes place annually on 2 January in Cape Town, South Africa.", :url "https://en.wikipedia.org/wiki/Kaapse_Klopse", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.heritage.robben-island", :name "Robben Island", :country "ZAF", :kind :heritage, :summary "South African National Heritage Site and UNESCO World Heritage Site (designated 1999) where Nelson Mandela was imprisoned for 18 of his 27 years before becoming South Africa's first Black president.", :url "https://en.wikipedia.org/wiki/Robben_Island", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "zaf.heritage.cradle-of-humankind", :name "Cradle of Humankind", :country "ZAF", :kind :heritage, :summary "Paleoanthropological site complex about 50 km northwest of Johannesburg in Gauteng province, declared a UNESCO World Heritage Site in 1999 and holding the largest known concentration of human ancestral remains anywhere in the world.", :url "https://en.wikipedia.org/wiki/Cradle_of_Humankind", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
